<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/zuppon_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Items del pedido -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🍔  " android:textSize="15sp" />
            <TextView
                android:id="@+id/tv_pending_items"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="14sp" android:textStyle="bold"
                android:maxLines="2" android:ellipsize="end" />
        </LinearLayout>

        <!-- Destino -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📍  " android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_pending_destination"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/zuppon_text_secondary"
                android:textSize="13sp"
                android:maxLines="2" android:ellipsize="end" />
        </LinearLayout>

        <!-- Tarifa -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💰  " android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_pending_fare"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/zuppon_yellow"
                android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Botón aceptar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept_order"
            style="@style/ZupponButtonGreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Aceptar pedido" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
