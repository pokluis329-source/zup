<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zuppon_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── FOTO GRANDE ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <!-- Gradiente fallback -->
            <View
                android:id="@+id/v_detail_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Foto real -->
            <ImageView
                android:id="@+id/iv_detail_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Foto del plato" />

            <!-- Overlay bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_gradient_bottom_dark" />

            <!-- Botón atrás -->
            <TextView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@drawable/bg_black_pill" />

            <!-- Badge popular -->
            <TextView
                android:id="@+id/tv_detail_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:text="🔥 Popular"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_accent_pill"
                android:visibility="gone" />

            <!-- Precio sobre la foto -->
            <TextView
                android:id="@+id/tv_detail_price_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:shadowColor="#88000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6" />

        </FrameLayout>

        <!-- ── INFO CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_rounded"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- Nombre + categoría -->
            <TextView
                android:id="@+id/tv_detail_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1" />

            <TextView
                android:id="@+id/tv_detail_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/zuppon_accent"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/zuppon_divider"
                android:layout_marginBottom="16dp" />

            <!-- Descripción completa -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingredientes"
                android:textColor="@color/zuppon_text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp" />

            <!-- Detalles extra: tiempo + calorías -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/zuppon_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⏱" android:textSize="22sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="20-30 min" android:textColor="@color/white"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="entrega" android:textColor="@color/zuppon_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/zuppon_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⭐" android:textSize="22sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4.8" android:textColor="@color/zuppon_yellow"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="rating" android:textColor="@color/zuppon_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/zuppon_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔥" android:textSize="22sp" />
                        <TextView
                            android:id="@+id/tv_detail_calories"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/zuppon_accent"
                            android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="kcal" android:textColor="@color/zuppon_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Selector de cantidad -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cantidad"
                android:textColor="@color/zuppon_text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <!-- Botón − -->
                <TextView
                    android:id="@+id/btn_detail_minus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_neon_card" />

                <!-- Cantidad -->
                <TextView
                    android:id="@+id/tv_detail_qty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- Botón + -->
                <TextView
                    android:id="@+id/btn_detail_plus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_accent_pill" />
            </LinearLayout>

            <!-- Botón agregar al carrito -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_to_cart"
                style="@style/ZupponButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Agregar al carrito" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
