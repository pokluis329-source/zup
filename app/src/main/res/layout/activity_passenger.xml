<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zuppon_primary">

    <!-- ── TOP BAR ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@color/zuppon_primary_dark"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_toolbar_logo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="Zuppon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_change_role"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="salir" android:textColor="@color/zuppon_text_hint" android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════════════════════════════════
         PANTALLA 1: MENÚ
         ══════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layout_menu_screen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="110dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/zuppon_primary_dark"
                android:paddingStart="20dp" android:paddingEnd="20dp"
                android:paddingTop="20dp" android:paddingBottom="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/where_to" android:textColor="@color/white"
                    android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="disponible ahora mismo 🔥" android:textColor="@color/zuppon_accent"
                    android:textSize="13sp" android:layout_marginBottom="16dp" />

                <!-- Campo dirección + botón GPS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_destination"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/destination_hint"
                        app:boxStrokeColor="@color/zuppon_accent"
                        app:boxBackgroundColor="@color/zuppon_card"
                        app:hintTextColor="@color/zuppon_text_secondary"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusBottomEnd="14dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_destination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/zuppon_text_primary"
                            android:imeOptions="actionDone"
                            android:inputType="textPostalAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón GPS -->
                    <TextView
                        android:id="@+id/btn_gps"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="📍"
                        android:textSize="22sp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_accent_pill"
                        android:contentDescription="Usar mi ubicación GPS" />

                    <!-- Botón elegir en mapa -->
                    <TextView
                        android:id="@+id/btn_pick_map"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="🗺️"
                        android:textSize="22sp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_neon_card"
                        android:contentDescription="Elegir ubicación en el mapa" />
                </LinearLayout>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:background="@color/zuppon_primary"
                android:paddingTop="14dp" android:paddingBottom="14dp">
                <LinearLayout
                    android:id="@+id/ll_categories"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp" android:paddingEnd="16dp" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_food_items"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Carrito flotante -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_cart_button"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/zuppon_accent" app:cardCornerRadius="20dp" app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="14dp" android:paddingBottom="14dp">
            <TextView android:id="@+id/tv_cart_count_badge"
                android:layout_width="30dp" android:layout_height="30dp"
                android:background="@drawable/bg_white_circle" android:gravity="center"
                android:textColor="@color/zuppon_accent" android:textSize="13sp" android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ver mi pedido 🛵" android:textColor="@color/white"
                android:textSize="15sp" android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />
            <TextView android:id="@+id/tv_cart_total_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════════════════════
         PANTALLA 2: CONFIRMAR PEDIDO
         ══════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layout_confirm_screen"
        android:layout_width="0dp" android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="tu pedido 🛒" android:textColor="@color/white"
                android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="revísalo antes de confirmar"
                android:textColor="@color/zuppon_text_secondary" android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/zuppon_card"
                app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:id="@+id/ll_cart_summary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" />
            </androidx.cardview.widget.CardView>

            <!-- Total + tiempo -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="20dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/zuppon_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="total 💰" android:textColor="@color/zuppon_text_secondary" android:textSize="12sp" />
                        <TextView android:id="@+id/tv_estimated_price"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/zuppon_yellow" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/zuppon_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="llega en ⏱" android:textColor="@color/zuppon_text_secondary" android:textSize="12sp" />
                        <TextView android:id="@+id/tv_estimated_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/zuppon_green" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Datos para el pago -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="datos para el pago 💳"
                android:textColor="@color/zuppon_text_primary" android:textSize="15sp"
                android:textStyle="bold" android:layout_marginBottom="10dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_buyer_name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="nombre"
                app:boxStrokeColor="@color/zuppon_accent"
                app:boxBackgroundColor="@color/zuppon_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_buyer_name"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/zuppon_text_primary" android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_buyer_email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="email"
                app:boxStrokeColor="@color/zuppon_accent"
                app:boxBackgroundColor="@color/zuppon_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_buyer_email"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/zuppon_text_primary" android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_buyer_phone"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="teléfono"
                app:boxStrokeColor="@color/zuppon_accent"
                app:boxBackgroundColor="@color/zuppon_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_buyer_phone"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/zuppon_text_primary" android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dirección con GPS -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="¿dónde te lo llevamos? 📍"
                android:textColor="@color/zuppon_text_primary" android:textSize="15sp"
                android:textStyle="bold" android:layout_marginBottom="10dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_delivery_address"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:hint="@string/destination_hint"
                    app:boxStrokeColor="@color/zuppon_accent"
                    app:boxBackgroundColor="@color/zuppon_card"
                    app:hintTextColor="@color/zuppon_text_secondary"
                    app:boxCornerRadiusTopStart="14dp" app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp" app:boxCornerRadiusBottomEnd="14dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_delivery_address"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/zuppon_text_primary"
                        android:inputType="textPostalAddress" />
                </com.google.android.material.textfield.TextInputLayout>
                <TextView
                    android:id="@+id/btn_gps_confirm"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:gravity="center" android:text="📍" android:textSize="22sp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_accent_pill"
                    android:contentDescription="Usar mi ubicación GPS" />

                <TextView
                    android:id="@+id/btn_pick_map_confirm"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:gravity="center" android:text="🗺️" android:textSize="22sp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_neon_card"
                    android:contentDescription="Elegir ubicación en el mapa" />
            </LinearLayout>

            <!-- Mini mapa interactivo para ajustar la ubicación exacta -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="200dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/zuppon_card"
                app:cardCornerRadius="18dp" app:cardElevation="0dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Mapa de confirmación -->
                    <FrameLayout
                        android:id="@+id/map_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Pin fijo en el centro — siempre visible, indica el punto exacto -->
                    <TextView
                        android:id="@+id/iv_center_pin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="📍"
                        android:textSize="32sp"
                        android:translationY="-16dp"
                        android:elevation="8dp" />

                    <!-- Instrucción de arrastre -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:background="#99000000"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:text="Arrastrá para ajustar el punto exacto"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:elevation="8dp" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Dirección detectada (solo lectura) -->
            <TextView
                android:id="@+id/tv_confirm_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/zuppon_text_secondary"
                android:textSize="13sp"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_request_ride"
                style="@style/ZupponButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="💳 Pagar con Pagopar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back_to_menu"
                style="@style/ZupponButtonOutline"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="← seguir eligiendo" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════════════
         PANTALLA 3: SEGUIMIENTO con Google Maps
         ══════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/layout_tracking_screen"
        android:layout_width="0dp" android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Google Maps ocupa toda la pantalla -->
        <fragment
            android:id="@+id/map_tracking"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Badge de estado encima del mapa -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_status_badge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/zuppon_card"
            app:cardCornerRadius="30dp" app:cardElevation="8dp">
            <TextView android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingStart="20dp" android:paddingEnd="20dp"
                android:paddingTop="10dp" android:paddingBottom="10dp"
                android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- Panel inferior -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_rounded"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="24dp" android:paddingBottom="28dp">

            <!-- Info repartidor -->
            <LinearLayout
                android:id="@+id/card_driver_info"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:visibility="gone" android:layout_marginBottom="20dp">
                <TextView android:id="@+id/tv_driver_avatar"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:text="🛵" android:textSize="30sp" android:gravity="center"
                    android:background="@drawable/bg_neon_card" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                    <TextView android:id="@+id/tv_driver_name"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_driver_car"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/zuppon_text_secondary" android:textSize="12sp" android:layout_marginTop="2dp" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="4dp">
                        <TextView android:id="@+id/tv_driver_rating"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/zuppon_yellow" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tv_driver_eta"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/zuppon_green" android:textSize="12sp"
                            android:textStyle="bold" android:layout_marginStart="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Buscando -->
            <LinearLayout android:id="@+id/layout_searching"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:visibility="gone">
                <ProgressBar android:id="@+id/progress_searching"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:indeterminateTint="@color/zuppon_accent" android:layout_marginBottom="10dp" />
                <TextView android:id="@+id/tv_searching_text"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/searching_driver" android:textColor="@color/white"
                    android:textSize="17sp" android:textStyle="bold"
                    android:gravity="center" android:layout_marginBottom="16dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_ride"
                    style="@style/ZupponButtonOutline"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/cancel_ride" />
            </LinearLayout>

            <!-- Completado -->
            <LinearLayout android:id="@+id/layout_completed"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎉" android:textSize="52sp" android:layout_marginBottom="6dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/trip_completed" android:textColor="@color/white"
                    android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/rate_driver" android:textColor="@color/zuppon_text_secondary"
                    android:textSize="13sp" android:layout_marginBottom="14dp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="18dp">
                    <TextView android:id="@+id/star1" android:layout_width="44dp" android:layout_height="44dp"
